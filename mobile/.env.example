# ── Supabase (must match the web app's Supabase project) ──────────────────────
# Expo uses EXPO_PUBLIC_ prefix (equivalent to Next.js NEXT_PUBLIC_)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Web API base URL (for AI analysis endpoint) ───────────────────────────────
# Point to your deployed Next.js app or local dev server
EXPO_PUBLIC_API_URL=https://your-web-app.vercel.app

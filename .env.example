# ─────────────────────────────────────────────────────────────────────────────
# SmartPool AI — Environment Variables
# Copy this file to .env and fill in each value.
# NEVER commit .env to git. .env.example IS safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Service role key — server only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Legacy (Prisma/SQLite — kept for reference, no longer used) ───────────────
# DATABASE_URL="file:./dev.db"
# JWT_SECRET="..."

# ── AI ───────────────────────────────────────────────────────────────────────
# Get a free key at https://ai.google.dev
GEMINI_API_KEY="your_gemini_api_key_here"

# ── App URL ──────────────────────────────────────────────────────────────────
# Used for OAuth redirect URIs and email links. No trailing slash.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Google OAuth (Sign in with Google) ────────────────────────────────────────
# NOT read by this app's own code — Supabase Auth handles the OAuth exchange
# server-side. Create the OAuth Client in Google Cloud Console, then paste the
# Client ID + Secret into Supabase Dashboard -> Authentication -> Providers ->
# Google (not into this .env file). The redirect URI Google needs is your
# Supabase project's own callback: https://<project-ref>.supabase.co/auth/v1/callback
# Also set the OAuth consent screen's "App name"/logo there, or Google's sign-in
# screen will show your raw *.supabase.co project URL instead of your app name.

# ── Microsoft OAuth / Apple Sign In ───────────────────────────────────────────
# NOT CURRENTLY IMPLEMENTED — no UI offers these (only Google sign-in exists in
# app/(auth)/signup/page.tsx), and no code anywhere reads Microsoft/Apple env
# vars. Do not provision credentials for these; there is nothing to plug them
# into yet.

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
# Get webhook secret: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
# lib/plans.ts reads these exact 6 names (one monthly + one annual Price ID
# per paid plan, created in Stripe Dashboard -> Product catalog). Checkout
# returns a 500 for any plan whose pair is missing.
STRIPE_HOMEOWNER_PLUS_MONTHLY_PRICE_ID="price_..."
STRIPE_HOMEOWNER_PLUS_ANNUAL_PRICE_ID="price_..."
STRIPE_POOL_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_POOL_PRO_ANNUAL_PRICE_ID="price_..."
STRIPE_POOL_TEAM_MONTHLY_PRICE_ID="price_..."
STRIPE_POOL_TEAM_ANNUAL_PRICE_ID="price_..."

# ── Email (for password reset, verification, reports, beta) ──────────────────
# Uses Resend (https://resend.com) — free tier: 100 emails/day, 3,000/month
# Falls back to console.log in development when key is absent.
# IMPORTANT: EMAIL_FROM's domain must be added + verified (SPF/DKIM/DMARC DNS
# records) under the SAME Resend account that owns RESEND_API_KEY, or every
# send will fail with a "domain not verified" error from the Resend API.
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="HydroSource <noreply@hydrosource.appscloud365.com>"
# Recipient for internal beta/feedback notifications. Falls back to
# hydrosource.ai@appscloud365.com in code if unset.
SUPPORT_EMAIL="hydrosource.ai@appscloud365.com"

# ── Founder / Admin ────────────────────────────────────────────────────────────
# Required to view/manage feedback at GET/PATCH /api/feedback. Must be set —
# there is no fallback, so an unset value denies everyone rather than
# defaulting to a hardcoded address.
FOUNDER_EMAIL="hydrosource.ai@appscloud365.com"

# ── Beta mode ──────────────────────────────────────────────────────────────────
# When "true": every user gets full Pool Pro access for free and Stripe
# checkout is skipped entirely (lib/subscription.ts, app/api/stripe/create-checkout).
# Set to "false" (or remove) to switch on real Stripe billing.
BETA_MODE="true"

# ── AI accuracy benchmark (optional, admin-only) ──────────────────────────────
# Protects POST /api/ai/benchmark, which runs lib/analysis-benchmarks.ts'
# scenarios against the live Gemini model. If unset, the endpoint returns a
# 500 for everyone (fails closed) -- safe to leave unset if you don't need it.
BENCHMARK_SECRET="a_long_random_string"

# ── PostHog analytics (optional) ──────────────────────────────────────────────
# If unset, analytics calls are silently no-ops (no crash, but trial/upgrade/
# cancel events won't be tracked). Get keys at https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY="phc_your_posthog_key"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
